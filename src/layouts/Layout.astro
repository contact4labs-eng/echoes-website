---
import { Font } from 'astro:assets';
import '../styles/global.css';
import { site } from '@/lib/config';
import { buildRestaurantSchema } from '@/lib/schema';
import {
	defaultLocale,
	getAlternates,
	getHtmlLang,
	getOgLocale,
	useTranslations,
	type Locale,
} from '@/i18n/utils';

interface Props {
	locale?: Locale;
	title?: string;
	description?: string;
}

const locale: Locale = Astro.props.locale ?? defaultLocale;
const t = useTranslations(locale);

const title = Astro.props.title ?? t('meta.home.title');
const description = Astro.props.description ?? t('meta.home.description');
const canonical = `${site.url}${Astro.url.pathname.replace(/\/$/, '') || '/'}`;
const alternates = getAlternates(Astro.url.pathname, site.url);
const xDefault = `${site.url}/`;
const ogLocale = getOgLocale(locale);
const ogLocaleAlt = locale === 'el' ? 'en_US' : 'el_GR';
const schema = buildRestaurantSchema(locale);
const ogImage = `${site.url}${site.ogImage}`;
---

<!doctype html>
<html lang={getHtmlLang(locale)}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<meta name="theme-color" content="#f0e7d2" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />

		{alternates.map((alt) => (
			<link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
		))}
		<link rel="alternate" hreflang="x-default" href={xDefault} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={site.name} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:locale:alternate" content={ogLocaleAlt} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		{/* R4 magazine fonts. Cormorant + Crimson Pro + IBM Plex Mono are
		    above-the-fold on the cover, so preload them. Old Standard TT
		    only renders inside the contents overlay (lazy) — no preload. */}
		<Font cssVariable="--font-wordmark" preload />
		<Font cssVariable="--font-italic" preload />
		<Font cssVariable="--font-mono" preload />
		<Font cssVariable="--font-greek-display" />

		<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
	</head>
	<body class="min-h-svh bg-background text-foreground">
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground"
		>
			{t('a11y.skipToContent')}
		</a>
		<slot />

		<script>
			// Smooth scroll via Lenis — desktop only, off under prefers-reduced-motion.
			// The R4 magazine experience between spreads uses smooth wheel scrolling;
			// anchor link clicks from inside the ContentsOverlay are handled by the
			// island itself (preventDefault + scrollIntoView). This block ONLY wires
			// the wheel smoothing.
			import Lenis from 'lenis';

			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			const isTouch = window.matchMedia('(hover: none) and (pointer: coarse)').matches;

			if (!reduce && !isTouch) {
				const lenis = new Lenis({
					duration: 1.1,
					smoothWheel: true,
					wheelMultiplier: 1,
					touchMultiplier: 1.5,
				});
				// Expose the instance so in-page jump navigation (the
				// ContentsOverlay TOC) can scroll through Lenis. Native
				// scrollIntoView({ behavior: 'smooth' }) is cancelled while
				// Lenis is active, so the overlay calls window.lenis.scrollTo.
				(window as unknown as { lenis?: unknown }).lenis = lenis;
				const raf = (time: number) => {
					lenis.raf(time);
					requestAnimationFrame(raf);
				};
				requestAnimationFrame(raf);
			}
		</script>
	</body>
</html>
