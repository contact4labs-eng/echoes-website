---
import { Image } from 'astro:assets';
import type { Locale } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import { site } from '@/lib/config';
import facadeDay from '@/assets/photos/facade-day.jpg';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);

const street = locale === 'el' ? site.address.streetAddress : site.address.streetAddressEn;
const locality = locale === 'el' ? site.address.addressLocality : site.address.addressLocalityEn;
const altFacade = locale === 'el'
	? 'Η ημερήσια πρόσοψη του Echoes με τυρκουάζ κουφώματα και ριγέ τέντες'
	: 'The daytime Echoes facade with turquoise window frames and striped awnings';
---

<section id="visit" class="relative bg-background px-5 py-24 md:px-8 md:py-32 lg:py-40">
	<div class="mx-auto max-w-7xl">
		<div class="grid items-stretch gap-10 md:grid-cols-12 md:gap-12">
			<div class="md:col-span-6 lg:col-span-5" data-reveal="left">
				<p class="text-[11px] font-semibold tracking-[0.25em] text-primary uppercase">
					{t('visit.eyebrow')}
				</p>
				<h2 class="font-heading mt-4 text-balance text-4xl leading-[1.08] font-semibold tracking-tight text-foreground sm:text-5xl md:text-[3.25rem]">
					{t('visit.title')}
				</h2>

				<dl class="mt-10 space-y-7">
					<div>
						<dt class="text-[10px] font-semibold tracking-[0.25em] text-foreground/55 uppercase">
							{t('visit.addressLabel')}
						</dt>
						<dd class="mt-2 text-lg text-foreground">
							<a href={site.mapsSearchUrl} target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-primary">
								{street}<br />
								{locality} {site.address.postalCode}
							</a>
						</dd>
					</div>
					<div>
						<dt class="text-[10px] font-semibold tracking-[0.25em] text-foreground/55 uppercase">
							{t('visit.phoneLabel')}
						</dt>
						<dd class="mt-2 text-lg text-foreground">
							<a href={`tel:${site.phone}`} class="transition-colors hover:text-primary">
								{site.phoneDisplay}
							</a>
						</dd>
					</div>
					<div>
						<dt class="text-[10px] font-semibold tracking-[0.25em] text-foreground/55 uppercase">
							{t('visit.hoursLabel')}
						</dt>
						<dd class="mt-2 space-y-1.5 text-lg text-foreground/85">
							<div>{t('visit.hoursWeekdays')}</div>
							<div>{t('visit.hoursWeekends')}</div>
						</dd>
					</div>
				</dl>

				<div class="mt-10 flex flex-wrap items-center gap-3">
					<a
						href={site.mapsSearchUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex h-11 items-center rounded-full bg-primary px-6 text-sm font-semibold tracking-wide text-primary-foreground transition-all duration-300 hover:scale-[1.02]"
					>
						{t('visit.mapsCta')}
					</a>
					<a
						href={site.social.instagramUrl}
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex h-11 items-center rounded-full border border-foreground/20 px-6 text-sm font-semibold tracking-wide text-foreground transition-all duration-300 hover:border-foreground/50"
					>
						{t('visit.instagramCta')}
					</a>
				</div>
			</div>

			<div class="md:col-span-6 lg:col-span-7" data-reveal="right">
				<figure class="relative h-full overflow-hidden rounded-sm">
					<Image
						src={facadeDay}
						alt={altFacade}
						widths={[480, 768, 1024, 1280]}
						sizes="(min-width: 768px) 55vw, 100vw"
						format="webp"
						quality={84}
						loading="lazy"
						class="aspect-[3/4] h-full w-full object-cover md:aspect-auto md:min-h-[640px]"
					/>
				</figure>
			</div>
		</div>

		<div class="mt-14 hidden overflow-hidden rounded-sm border border-foreground/10 md:block" data-reveal="slow">
			<iframe
				title={locale === 'el' ? 'Χάρτης Echoes Bistrot' : 'Map of Echoes Bistrot'}
				src={site.mapsEmbedUrl}
				width="100%"
				height="380"
				style="border:0; filter: grayscale(0.25) contrast(1.05);"
				allowfullscreen="false"
				loading="lazy"
				referrerpolicy="no-referrer-when-downgrade"
			></iframe>
		</div>
	</div>
</section>
