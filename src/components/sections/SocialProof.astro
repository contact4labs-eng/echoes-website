---
import { Image } from 'astro:assets';
import type { Locale } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import { site } from '@/lib/config';
import partnerTaf from '@/assets/photos/partner-taf.jpg';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative bg-background px-5 py-24 md:px-8 md:py-32">
	<div class="mx-auto max-w-7xl">
		<div class="max-w-2xl" data-reveal>
			<p class="text-[11px] font-semibold tracking-[0.25em] text-primary uppercase">
				{t('social.eyebrow')}
			</p>
			<h2 class="font-heading mt-4 text-balance text-4xl leading-[1.08] font-semibold tracking-tight text-foreground sm:text-5xl md:text-[3rem]">
				{t('social.title')}
			</h2>
		</div>

		<div class="mt-14 grid items-stretch gap-6 md:grid-cols-2 md:gap-8" data-reveal-stagger>
			<article class="flex flex-col gap-5 rounded-sm border border-foreground/10 bg-card p-8 md:p-10">
				<div class="flex items-center justify-between">
					<span class="text-[11px] font-semibold tracking-[0.25em] text-foreground/55 uppercase">
						Press
					</span>
					<span class="text-xs text-foreground/55">{t('social.pressDate')}</span>
				</div>
				<blockquote class="font-heading text-2xl leading-tight text-balance text-foreground md:text-3xl">
					{t('social.pressQuote')}
				</blockquote>
				<div class="mt-auto pt-4">
					<a
						href="https://www.noupou.gr/food-drink/brunch/echoes-neo-brunch-spot-stin-ilioupoli/"
						target="_blank"
						rel="noopener noreferrer"
						class="text-sm font-semibold tracking-wide text-primary transition-colors hover:text-primary/80"
					>
						{t('social.pressName')} →
					</a>
				</div>
			</article>

			<article class="flex flex-col gap-5 overflow-hidden rounded-sm border border-foreground/10 bg-card md:flex-row">
				<div class="relative aspect-[4/3] w-full overflow-hidden bg-bistro-teal md:aspect-auto md:w-1/2">
					<Image
						src={partnerTaf}
						alt={locale === 'el' ? 'Πινακίδα Taf Coffee στον πάγκο του μπαρ' : 'Taf Coffee plaque at the bar counter'}
						widths={[320, 480, 640]}
						sizes="(min-width: 768px) 320px, 90vw"
						format="webp"
						quality={84}
						loading="lazy"
						class="h-full w-full object-cover"
					/>
				</div>
				<div class="flex flex-col justify-center gap-3 p-8 md:flex-1 md:p-10">
					<span class="text-[11px] font-semibold tracking-[0.25em] text-foreground/55 uppercase">
						{t('social.partnerLabel')}
					</span>
					<h3 class="font-heading text-3xl font-semibold tracking-tight text-foreground">
						{t('social.partnerName')}
					</h3>
					<p class="text-sm leading-relaxed text-foreground/65">
						{locale === 'el'
							? 'Καθημερινός καφές σε συνεργασία με ένα από τα πιο γνωστά specialty roasteries της Αθήνας.'
							: 'Daily coffee in partnership with one of Athens’ most respected specialty roasters.'}
					</p>
				</div>
			</article>
		</div>
	</div>
</section>
