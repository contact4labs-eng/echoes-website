---
import { Image } from 'astro:assets';
import type { Locale } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import chefPlatingWide from '@/assets/photos/chef-plating-wide.jpg';
import chefCopperlamp from '@/assets/photos/chef-copperlamp.jpg';
import chefPouring from '@/assets/photos/chef-pouring.jpg';
import chefViola from '@/assets/photos/chef-viola.png';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);

const altWide = locale === 'el' ? 'Σεφ ολοκληρώνει πιάτο στη γραμμή της κουζίνας' : 'Chef finishing a dish on the line';
const altCopper = locale === 'el' ? 'Σερβίρισμα κάτω από χάλκινη καμπάνα θέρμανσης' : 'Plating under a copper heat lamp';
const altPour = locale === 'el' ? 'Σερβίρισμα από μπρίκι σε λευκή κούπα' : 'Pouring from a briki into a white cup';
const altViola = locale === 'el' ? 'Τοποθέτηση βρώσιμου άνθους viola σε πιάτο επιδορπίου' : 'Placing an edible viola on a plated dessert';
---

<section id="chef" class="relative overflow-hidden bg-bistro-ink px-5 py-24 text-bistro-cream md:px-8 md:py-32 lg:py-40">
	<div class="mx-auto max-w-7xl">
		<div class="max-w-3xl" data-reveal="editorial">
			<p class="text-[11px] font-semibold tracking-[0.25em] text-bistro-copper uppercase">
				{t('chef.eyebrow')}
			</p>
			<h2 class="font-heading mt-4 text-balance text-4xl leading-[1.08] font-semibold tracking-tight text-bistro-cream sm:text-5xl md:text-[3.25rem]">
				{t('chef.title')}
			</h2>
			<p class="mt-7 max-w-2xl text-lg leading-relaxed text-bistro-cream/75 md:text-xl">
				{t('chef.body')}
			</p>
		</div>

		<figure class="relative mt-14 overflow-hidden rounded-sm" data-reveal="editorial">
			<Image
				src={chefPlatingWide}
				alt={altWide}
				widths={[640, 960, 1280, 1600]}
				sizes="(min-width: 1024px) 1200px, 100vw"
				format="webp"
				quality={84}
				class="kenburns aspect-[16/10] h-full w-full object-cover md:aspect-[16/8]"
			/>
		</figure>

		<div class="mt-6 grid grid-cols-3 gap-4 md:mt-8 md:gap-6" data-reveal-stagger>
			<figure class="relative overflow-hidden rounded-sm">
				<Image
					src={chefCopperlamp}
					alt={altCopper}
					widths={[240, 400, 640]}
					sizes="(min-width: 1024px) 380px, 32vw"
					format="webp"
					quality={82}
					class="aspect-[4/5] h-full w-full object-cover transition-transform duration-700 hover:scale-105"
				/>
			</figure>
			<figure class="relative overflow-hidden rounded-sm">
				<Image
					src={chefPouring}
					alt={altPour}
					widths={[240, 400, 640]}
					sizes="(min-width: 1024px) 380px, 32vw"
					format="webp"
					quality={82}
					class="aspect-[4/5] h-full w-full object-cover transition-transform duration-700 hover:scale-105"
				/>
			</figure>
			<figure class="relative overflow-hidden rounded-sm">
				<Image
					src={chefViola}
					alt={altViola}
					widths={[240, 400, 640]}
					sizes="(min-width: 1024px) 380px, 32vw"
					format="webp"
					quality={82}
					class="aspect-[4/5] h-full w-full object-cover transition-transform duration-700 hover:scale-105"
				/>
			</figure>
		</div>
	</div>
</section>
