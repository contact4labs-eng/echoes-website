---
import { Image } from 'astro:assets';
import type { Locale } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import facadeBougainvillea from '@/assets/photos/facade-bougainvillea.jpg';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section id="story" class="relative bg-background px-5 py-24 md:px-8 md:py-32 lg:py-40">
	<div class="mx-auto grid max-w-7xl items-center gap-12 md:grid-cols-12 md:gap-16 lg:gap-24">
		<div class="md:col-span-6 lg:col-span-5" data-reveal="left">
			<p class="text-[11px] font-semibold tracking-[0.25em] text-primary uppercase">
				{t('story.eyebrow')}
			</p>
			<h2 class="font-heading mt-4 text-balance text-4xl leading-[1.08] font-semibold tracking-tight text-foreground sm:text-5xl md:text-[3.25rem]">
				{t('story.title')}
			</h2>
			<div class="mt-7 space-y-5 text-lg leading-relaxed text-foreground/75 md:text-xl">
				<p>{t('story.bodyA')}</p>
				<p>{t('story.bodyB')}</p>
			</div>
			<div class="mt-10 flex items-center gap-4">
				<span class="h-px w-12 bg-foreground/25"></span>
				<span class="text-[11px] font-medium tracking-[0.2em] text-foreground/55 uppercase">
					Νυμφών 33 · Ηλιούπολη
				</span>
			</div>
		</div>

		<div class="md:col-span-6 lg:col-span-7" data-reveal="right">
			<figure class="story-figure relative overflow-hidden rounded-sm">
				<Image
					src={facadeBougainvillea}
					alt={
						locale === 'el'
							? 'Η πρόσοψη του Echoes με κόκκινη μπουκαμβίλια και κόκκινες-κίτρινες τέντες'
							: 'The Echoes facade with red bougainvillea and red-yellow striped awnings'
					}
					widths={[480, 768, 1024, 1280, 1600]}
					sizes="(min-width: 768px) 55vw, 100vw"
					format="webp"
					quality={85}
					class="story-image aspect-[4/5] h-full w-full object-cover"
				/>
				<div class="absolute inset-0 bg-gradient-to-tr from-bistro-ink/15 via-transparent to-transparent" aria-hidden="true"></div>
			</figure>
		</div>
	</div>
</section>

<style>
	.story-figure { transform: translateZ(0); }
	.story-image {
		transition: transform 1.4s cubic-bezier(0.22, 1, 0.36, 1);
	}
	[data-reveal].is-revealed .story-image {
		transform: scale(1.0);
	}
	.story-image:not(.is-revealed) {
		transform: scale(1.04);
	}
	.story-figure:hover .story-image {
		transform: scale(1.03);
	}
</style>
