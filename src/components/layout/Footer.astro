---
import type { Locale } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import { site } from '@/lib/config';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);

const streetLine = locale === 'el' ? site.address.streetAddress : site.address.streetAddressEn;
const localityLine =
	(locale === 'el' ? site.address.addressLocality : site.address.addressLocalityEn) +
	' ' + site.address.postalCode;

const year = new Date().getFullYear();
const copy = t('footer.copyright').replace('{year}', String(year));
---

<footer class="border-t border-foreground/10 bg-background px-5 py-14 md:px-8 md:py-20">
	<div class="mx-auto flex max-w-7xl flex-col gap-10 md:flex-row md:justify-between">
		<div class="max-w-sm">
			<a href="/" class="font-heading text-3xl font-semibold tracking-tight text-foreground">
				{site.wordmark}
			</a>
			<p class="mt-3 max-w-[28ch] text-base text-foreground/70">{t('footer.tagline')}</p>
		</div>

		<div class="grid grid-cols-2 gap-10 md:grid-cols-3 md:gap-16">
			<div>
				<h3 class="text-[11px] font-semibold tracking-[0.2em] text-foreground/55 uppercase">{t('footer.section.visit')}</h3>
				<address class="mt-3 not-italic text-sm leading-relaxed text-foreground/85">
					{streetLine}<br />
					{localityLine}<br />
					<a href={`tel:${site.phone}`} class="transition-colors hover:text-primary">{site.phoneDisplay}</a>
				</address>
			</div>
			<div>
				<h3 class="text-[11px] font-semibold tracking-[0.2em] text-foreground/55 uppercase">{t('footer.section.hours')}</h3>
				<dl class="mt-3 space-y-2 text-sm text-foreground/85">
					<div>{t('visit.hoursWeekdays')}</div>
					<div>{t('visit.hoursWeekends')}</div>
				</dl>
			</div>
			<div class="col-span-2 md:col-span-1">
				<h3 class="text-[11px] font-semibold tracking-[0.2em] text-foreground/55 uppercase">{t('footer.section.follow')}</h3>
				<a
					href={site.social.instagramUrl}
					target="_blank"
					rel="noopener noreferrer"
					class="mt-3 inline-flex items-center gap-2 text-sm text-foreground/85 transition-colors hover:text-primary"
					aria-label={t('a11y.openInstagram')}
				>
					<svg
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.7"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
						<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
						<line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
					</svg>
					<span>@{site.social.instagramHandle}</span>
				</a>
			</div>
		</div>
	</div>
	<p class="mx-auto mt-14 max-w-7xl text-xs text-foreground/45">{copy}</p>
</footer>
