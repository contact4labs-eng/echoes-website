---
import type { Locale } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import { site } from '@/lib/config';
import LangSwitcher from './LangSwitcher.astro';
import { MobileNav } from './MobileNav';

interface Props {
	locale: Locale;
	pathname: string;
}

const { locale, pathname } = Astro.props;
const t = useTranslations(locale);

// Three anchors. Section IDs match `data-nav-link` ids so the active-nav IO can
// pair them. Threshold / First Word / Through the Door / Slow Hours / End Card
// aren't nav-anchor targets — they're cinematic moments, not navigable sections.
const links = [
	{ href: '#menu', label: t('nav.menu'), id: 'menu' },
	{ href: '#kitchen', label: t('nav.kitchen'), id: 'kitchen' },
	{ href: '#visit', label: t('nav.visit'), id: 'visit' },
];

const telHref = `tel:${site.phone}`;
const igHref = site.social.instagramDm;
---

<header
	data-site-header
	class="fixed inset-x-0 top-0 z-40 transition-[background-color,backdrop-filter,border-color] duration-300"
>
	<div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-3 md:px-8 md:py-4">
		<a
			href="/"
			class="font-heading text-2xl font-semibold tracking-tight text-[var(--header-fg-strong)] transition-[color,opacity] duration-300 hover:opacity-80 md:text-3xl"
		>
			{site.wordmark}
		</a>

		<nav class="hidden items-center gap-9 md:flex" aria-label={t('nav.menu')}>
			{links.map((l) => (
				<a
					href={l.href}
					data-nav-link={l.id}
					class="nav-link text-[13px] font-medium tracking-[0.04em] text-[var(--header-fg-muted)] transition-colors duration-300 hover:text-[var(--header-fg-strong)]"
				>
					{l.label}
				</a>
			))}
		</nav>

		<div class="flex items-center gap-3 md:gap-5">
			<LangSwitcher locale={locale} pathname={pathname} />
			<a
				href={telHref}
				class="hidden h-9 items-center rounded-md bg-[var(--header-cta-bg)] px-4 text-[13px] font-semibold tracking-wide text-[var(--header-cta-fg)] transition-[background-color,color] duration-300 hover:bg-[var(--header-cta-bg-hover)] md:inline-flex"
				aria-label={t('a11y.callPhone').replace('{phone}', site.phoneDisplay)}
			>
				{t('nav.reserve')}
			</a>
			<MobileNav
				client:idle
				openLabel={t('a11y.openMenu')}
				closeLabel={t('a11y.closeMenu')}
				navLabel={t('nav.menu')}
				links={links}
				ctaLabel={t('nav.reserve')}
				ctaHref={telHref}
				secondaryLabel={t('visit.instagramCta')}
				secondaryHref={igHref}
			/>
		</div>
	</div>
</header>
