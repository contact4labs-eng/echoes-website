---
import type { Locale } from '@/i18n/utils';
import { useTranslations, getLocalePath, stripLocale } from '@/i18n/utils';

interface Props {
	locale: Locale;
	pathname: string;
}

const { locale, pathname } = Astro.props;
const t = useTranslations(locale);
const otherLocale: Locale = locale === 'el' ? 'en' : 'el';
const otherHref = getLocalePath(stripLocale(pathname), otherLocale);
const otherLabel = otherLocale.toUpperCase();
const activeLabel = locale.toUpperCase();
---

<div class="flex items-center gap-1.5 text-[11px] font-medium tracking-[0.18em] uppercase">
	<span class="text-[var(--header-fg-strong)] transition-colors duration-300" aria-current="page">{activeLabel}</span>
	<span class="text-[var(--header-fg-faint)] transition-colors duration-300" aria-hidden="true">·</span>
	<a
		href={otherHref}
		hreflang={otherLocale === 'el' ? 'el-GR' : 'en-US'}
		class="text-[var(--header-fg-muted)] transition-colors duration-300 hover:text-[var(--header-fg-strong)]"
		aria-label={t('a11y.switchLang')}
	>
		{otherLabel}
	</a>
</div>
