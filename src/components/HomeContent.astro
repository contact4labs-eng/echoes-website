---
/**
 * R4 Phase 1 — HomeContent
 * Renders only the Cover spread + ContentsOverlay React island.
 * - Header is NOT imported — the magazine cover absorbs the brand
 *   identity; there is no top nav bar in R4.
 * - Footer is NOT rendered. The legacy Footer carries banned copy
 *   ("Designed with care in Athens" / "Σχεδιάστηκε με φροντίδα στην
 *   Αθήνα") that must not appear in built output. It will be replaced
 *   by a Colophon spread in a later phase; until then the cover stands
 *   alone as a one-screen experience.
 */
import type { Locale } from '@/i18n/utils';
import { useTranslations } from '@/i18n/utils';
import { site } from '@/lib/config';
import Cover from '@/components/spreads/Cover.astro';
import { ContentsOverlay } from '@/components/interactive/ContentsOverlay';

interface Props {
	locale: Locale;
	pathname: string;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const phoneHref = `tel:${site.phone}`;

// Phase 1: only the Cover exists as a spread, so the contents overlay
// shows a single entry. As new spreads land in later phases their
// entries are added here (and become anchors on the page).
const entries = [
	{
		page: t('contents.entries.cover.page'),
		title: t('contents.entries.cover.title'),
		blurb: t('contents.entries.cover.blurb'),
		href: '#main',
	},
];
---

<main id="main">
	<Cover locale={locale} />
</main>

<ContentsOverlay
	client:idle
	eyebrow={t('contents.eyebrow')}
	title={t('contents.title')}
	closeLabel={t('contents.closeLabel')}
	entries={entries}
	footerLeft={t('contents.footerLeft')}
	footerPhone={t('contents.footerPhone')}
	footerPhoneHref={phoneHref}
/>
