---
import type { Locale } from '@/i18n/utils';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import Threshold from '@/components/sections/Threshold.astro';
import FirstWord from '@/components/sections/FirstWord.astro';
import ThroughTheDoor from '@/components/sections/ThroughTheDoor.astro';
import SlowHours from '@/components/sections/SlowHours.astro';
import FromTheKitchen from '@/components/sections/FromTheKitchen.astro';
import ThePass from '@/components/sections/ThePass.astro';
import Nymfon33 from '@/components/sections/Nymfon33.astro';
import EndCard from '@/components/sections/EndCard.astro';

interface Props {
	locale: Locale;
	pathname: string;
}

const { locale, pathname } = Astro.props;
---

<Header locale={locale} pathname={pathname} />

<main id="main">
	<Threshold locale={locale} />
	<FirstWord locale={locale} />
	<ThroughTheDoor locale={locale} />
	<SlowHours locale={locale} />
	<FromTheKitchen locale={locale} />
	<ThePass locale={locale} />
	<Nymfon33 locale={locale} />
	<EndCard locale={locale} />
</main>

<Footer locale={locale} />
